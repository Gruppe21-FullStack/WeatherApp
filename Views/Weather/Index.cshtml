@model IEnumerable<WeatherApp.Models.Weather>

@{
    ViewData["Title"] = "Weather History";
}

<h1>Weather History</h1>

<table class="table">
    <thead>
        <tr>
            <th>City</th>
            <th>Temperature (°C)</th>
            <th>Description</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.OrderByDescending(w => w.Date)) {
        <tr>
            <td>
                @item.City.Name
            </td>
            <td>
                @item.Temperature
            </td>
            <td>
                @item.Description
            </td>
            <td>
                @item.Date.ToString("yyyy-MM-dd HH:mm")
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>